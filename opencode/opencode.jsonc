{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      // .env 系はデフォルトでdeny
      "*.key": "deny",
      "*.pem": "deny",
      "*credentials*": "deny",
      "*secret*": "deny"
    },
    "bash": {
      "*": "ask",
      "git *": "allow",
      "git push": "ask",
      "git push *": "ask",
      "ls *": "allow"
    },
    "todowrite": "allow",
    "todoread": "allow",
    "edit": "ask",
    "webfetch": "ask",
    "websearch": "ask"
  }
}
